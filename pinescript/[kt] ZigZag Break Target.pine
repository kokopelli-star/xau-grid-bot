//     sl = close - atr * atrRiskMul
//     tp = close + atr * tpMul
//     strategy.entry("LongReversal", strategy.long)
//     strategy.exit("LongExit", "LongReversal", stop=sl, limit=tp)

// if (shortCondition) and (strategy.position_size == 0)
//     sl = close + atr * atrRiskMul
//     tp = close - atr * tpMul
//     strategy.entry("ShortReversal", strategy.short)
//     strategy.exit("ShortExit", "ShortReversal", stop=sl, limit=tp)
